# Acceso a la app (Basic Auth)
# Elegí valores fuertes. La app exige auth siempre: si no seteás estas vars,
# se usan defaults inseguros (arca/changeme).
APP_LOGIN_USER=
APP_LOGIN_PASSWORD=

# ARCA/AFIP Configuration
ARCA_CUIT=
ARCA_PV_C=
ARCA_PV_E=
ARCA_CERT_PATH=
ARCA_KEY_PATH=
ARCA_ENV=production

# Vercel Blob (factura history — production; local dev uses .data/facturas-index.json)
BLOB_READ_WRITE_TOKEN=

# ARCA Web Services URLs (Production)
ARCA_WSAA_URL=https://wsaa.afip.gov.ar/ws/services/LoginCms
ARCA_WSFE_URL=https://servicios1.afip.gov.ar/wsfev1/service.asmx

